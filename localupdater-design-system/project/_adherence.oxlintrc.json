{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/**",
              "components/display/**",
              "components/forms/**",
              "components/navigation/**",
              "ui_kits/localupdater/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter|Noto Sans JP|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Inter, Noto Sans JP, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|size|dot|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, size, dot."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Badge> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|leftIcon|rightIcon|iconSize|fullWidth|loading|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, leftIcon, rightIcon, iconSize, fullWidth, loading."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|padding|elevation|selected|interactive|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, padding, elevation, selected, interactive."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='elevation'] > Literal[value!=/^(?:flat|sm|md|lg)$/]",
        "message": "<Card> elevation must be one of 'flat' | 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|selected|onClick|leftIcon|count|size|variant|removable|onRemove|style|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: children, selected, onClick, leftIcon, count, size, variant, removable, onRemove, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Chip> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default)$/]",
        "message": "<Chip> variant must be one of 'default'."
      },
      {
        "selector": "JSXOpeningElement[name.name='EmptyState'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|description|action|size|style|key|ref|className|style|children)$/]",
        "message": "<EmptyState> doesn't accept that prop. Declared props: icon, title, description, action, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='EmptyState'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<EmptyState> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FileRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|path|ext|size|modified|isNew|selected|onClick|trailing|density|style|key|ref|className|style|children)$/]",
        "message": "<FileRow> doesn't accept that prop. Declared props: name, path, ext, size, modified, isNew, selected, onClick, trailing, density, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='FileRow'] > JSXAttribute[name.name='density'] > Literal[value!=/^(?:comfortable|compact)$/]",
        "message": "<FileRow> density must be one of 'comfortable' | 'compact'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FileTypeBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:kind|ext|size|showLabel|color|icon|style|key|ref|className|style|children)$/]",
        "message": "<FileTypeBadge> doesn't accept that prop. Declared props: kind, ext, size, showLabel, color, icon, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|strokeWidth|title|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, strokeWidth, title."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|size|variant|active|title|ariaLabel|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: icon, size, variant, active, title, ariaLabel."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<IconButton> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:ghost|filled)$/]",
        "message": "<IconButton> variant must be one of 'ghost' | 'filled'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:leftIcon|clearable|size|fullWidth|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: leftIcon, clearable, size, fullWidth."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Input> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='LocalUpdaterApp'] > JSXAttribute > JSXIdentifier[name!=/^(?:defaultView|defaultTheme|key|ref|className|style|children)$/]",
        "message": "<LocalUpdaterApp> doesn't accept that prop. Declared props: defaultView, defaultTheme."
      },
      {
        "selector": "JSXOpeningElement[name.name='LocalUpdaterApp'] > JSXAttribute[name.name='defaultView'] > Literal[value!=/^(?:list|timeline|calendar)$/]",
        "message": "<LocalUpdaterApp> defaultView must be one of 'list' | 'timeline' | 'calendar'."
      },
      {
        "selector": "JSXOpeningElement[name.name='LocalUpdaterApp'] > JSXAttribute[name.name='defaultTheme'] > Literal[value!=/^(?:earth|night|light)$/]",
        "message": "<LocalUpdaterApp> defaultTheme must be one of 'earth' | 'night' | 'light'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SidebarItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|count|selected|depth|onClick|trailing|expandable|expanded|onToggle|reserveCaret|style|key|ref|className|style|children)$/]",
        "message": "<SidebarItem> doesn't accept that prop. Declared props: icon, label, count, selected, depth, onClick, trailing, expandable, expanded, onToggle, reserveCaret, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:left|center|right|style|key|ref|className|style|children)$/]",
        "message": "<StatusBar> doesn't accept that prop. Declared props: left, center, right, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|icon|count|key|ref|className|style|children)$/]",
        "message": "<TabItem> doesn't accept that prop. Declared props: value, label, icon, count."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toolbar'] > JSXAttribute > JSXIdentifier[name!=/^(?:left|center|right|children|style|key|ref|className|style|children)$/]",
        "message": "<Toolbar> doesn't accept that prop. Declared props: left, center, right, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='WindowFrame'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|subtitle|toolbar|statusBar|children|width|height|rounded|style|key|ref|className|style|children)$/]",
        "message": "<WindowFrame> doesn't accept that prop. Declared props: title, subtitle, toolbar, statusBar, children, width, height, rounded, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
